# Frontend Environment Variables

# Backend API URL
# For local development: http://localhost:5000
# For production: https://thara-mens-wear.onrender.com
REACT_APP_API_URL=https://thara-mens-wear.onrender.com

# Instructions:
# 1. Copy this file to .env.local for local development
# 2. Update REACT_APP_API_URL to http://localhost:5000 for local testing
# 3. For production, use the deployed backend URL
