PORT=5000
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
BASE_URL=http://localhost:5000

# Email Configuration (SendGrid API)
SENDGRID_API_KEY=SG.your_api_key_here
SENDGRID_FROM_EMAIL=abdulkani180607@gmail.com

# Instructions:
# 1. Copy this file to .env
# 2. Replace the placeholder values with your actual credentials
# 3. Get MongoDB connection string from: https://cloud.mongodb.com/
# 4. Get SendGrid API key from: https://app.sendgrid.com/settings/api_keys
# 5. Verify your sender email in SendGrid: https://app.sendgrid.com/settings/sender_auth
# 6. For production, update BASE_URL to your deployed backend URL
