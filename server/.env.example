PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
PUBLIC_URL=http://localhost:5000

# Email Configuration (Resend API)
RESEND_API_KEY=re_your_api_key_here

# Instructions:
# 1. Copy this file to .env
# 2. Replace username, password, cluster, and database with your actual values
# 3. For production, update PUBLIC_URL to your deployed backend URL
# 4. Get your Resend API key from: https://resend.com/api-keys
# 5. Replace re_your_api_key_here with your actual Resend API key
